# OPRAI profile: Inception Mercury 2 (direct API + tool agent)

export LLM_PROVIDER="inception"
export LLM_MODEL="mercury-2"
export LLM_FALLBACK_PROVIDER="disabled"

export INCEPTION_API_BASE="https://api.inceptionlabs.ai/v1"
export INCEPTION_EDIT_MODEL="mercury-edit-2"

# Chat path (no tools): fast, low hallucination on simple Q&A
# Mercury 2 valid temperature: 0.5–1.0 (values below 0.5 are clamped)
export INCEPTION_CHAT_REASONING_EFFORT="instant"
export INCEPTION_CHAT_TEMPERATURE="0.65"
export INCEPTION_CHAT_INCLUDE_CONTEXT="1"

# Agent path (tools): per Inception prompt guide / developer guide
export INCEPTION_AGENT_PLAN_REASONING_EFFORT="low"
export INCEPTION_AGENT_REASONING_EFFORT="medium"
export INCEPTION_AGENT_WRITE_REASONING_EFFORT="high"
export INCEPTION_AGENT_SYNTHESIS_REASONING_EFFORT="instant"
export INCEPTION_AGENT_TEMPERATURE="0.5"
export INCEPTION_AGENT_MAX_TOKENS="8192"
export INCEPTION_AGENT_SYNTHESIS_MAX_TOKENS="2048"
export INCEPTION_AGENT_MAX_STEPS="12"
export INCEPTION_AGENT_MAX_TOOL_TURNS="3"
export INCEPTION_AGENT_MAX_NUDGES="2"
export INCEPTION_AGENT_TIMEOUT_SECONDS="600"
export INCEPTION_REASONING_SUMMARY="0"
# Pipecat/OpenClaw patterns: faster tool steps + diffusion decode
export INCEPTION_REALTIME="true"
export INCEPTION_DIFFUSING="true"

# Force full agent loop even for short messages (debug)
export INCEPTION_FORCE_AGENT="0"

export CURSOR_AGENT_WORKSPACE="/home/opr"
export ORCHESTRATOR_CHAT_EXECUTION_MODE="llm_router"

# INCEPTION_API_KEY in env.secrets (not committed).
